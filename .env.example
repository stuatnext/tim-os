# Tim OS — environment template. Copy to .env.local and fill in.

# Anthropic API key for the AI agents (Opus 4.7 for briefs, Haiku 4.5 for ingestion).
ANTHROPIC_API_KEY=

# Prisma — Postgres (Neon / Vercel Postgres / Supabase).
# For local SQLite dev, also change provider in prisma/schema.prisma to "sqlite".
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Shared secret protecting /api/agents/* and /api/feeds/* from random callers.
# Cron pings these endpoints with `Authorization: Bearer $AGENT_SECRET`.
AGENT_SECRET=
